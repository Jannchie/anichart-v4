# Postgres 连接串（本地用 docker-compose.yml 起，端口 4305）
DATABASE_URL=postgres://anichart:anichart@localhost:4305/anichart

# better-auth：用 `openssl rand -base64 32` 生成
BETTER_AUTH_SECRET=replace-me-with-a-random-secret
BETTER_AUTH_URL=http://localhost:4300

# S3 兼容对象存储（本地 MinIO 走 docker-compose.yml，端口 4306；生产可换 R2/AWS S3）
S3_ENDPOINT=http://localhost:4306
S3_REGION=auto
S3_BUCKET=anichart
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
