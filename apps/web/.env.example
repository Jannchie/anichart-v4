# Postgres 连接串
DATABASE_URL=postgres://anichart:anichart@localhost:5432/anichart

# better-auth：用 `openssl rand -base64 32` 生成
BETTER_AUTH_SECRET=replace-me-with-a-random-secret
BETTER_AUTH_URL=http://localhost:3000

# S3 兼容对象存储（Cloudflare R2 / MinIO / AWS S3），存上传数据与作品封面
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=anichart
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
